  });
}
wirePillRow('role-row', 'role', v => { state.role = v; checkReady(); });
wirePillRow('depth-row', 'depth', v => { state.depth = v; });
wirePillRow('law-row', 'law', v => { state.law = v; });

// defaults
document.querySelector('[data-depth="core"]').classList.add('active');
document.querySelector('[data-law="both"]').classList.add('active');

function checkReady(){
  document.getElementById('start-btn').disabled = !state.role;
}

document.getElementById('start-btn').addEventListener('click', startQuiz);
document.getElementById('retake-btn').addEventListener('click', () => {
  document.getElementById('results-screen').classList.add('hidden');
  document.getElementById('intro-screen').classList.remove('hidden');
});

/* ============ FILTER + START ============ */
function filterQuestions(){
  let pool = QUESTIONS.filter(q => {
    const roleMatch = state.role === 'general' ? true : (q.roles.includes(state.role) || q.roles.includes('all'));
    const depthMatch = q.depth === state.depth;
    const lawMatch = state.law === 'both' ? true : (q.source_law === state.law || q.source_law === 'both');
    return roleMatch && depthMatch && lawMatch;
  });
  // fallback if too few questions: loosen depth first, then law
  if (pool.length < 6){
    pool = QUESTIONS.filter(q => {
      const roleMatch = state.role === 'general' ? true : (q.roles.includes(state.role) || q.roles.includes('all'));
      const lawMatch = state.law === 'both' ? true : (q.source_law === state.law || q.source_law === 'both');
      return roleMatch && lawMatch;
    });
  }
  if (pool.length < 6){
    pool = QUESTIONS.filter(q => state.role === 'general' ? true : (q.roles.includes(state.role) || q.roles.includes('all')));
  }
  // shuffle
  for (let i = pool.length - 1; i > 0; i--){
    const j = Math.floor(Math.random() * (i + 1));
    [pool[i], pool[j]] = [pool[j], pool[i]];
  }
  return pool;
}

function startQuiz(){
  state.quizQuestions = filterQuestions();
  state.index = 0;
  state.score = 0;
  state.answered = false;
  state.missed = [];
  document.getElementById('intro-screen').classList.add('hidden');
  document.getElementById('results-screen').classList.add('hidden');
  document.getElementById('quiz-screen').classList.remove('hidden');
  renderQuestion();
}

/* ============ QUIZ RENDER ============ */
const LAW_LABEL = { gdpr: "DSGVO", eu_ai_act: "EU-KI-Verordnung", both: "DSGVO + KI-VO" };
const ROLE_LABEL = { hr:"HR", marketing:"Marketing", sales:"Sales", engineering:"Engineering", legal:"Legal", exec:"Exec", general:"Allgemein" };

function renderQuestion(){
  const q = state.quizQuestions[state.index];
  state.answered = false;
  document.getElementById('quiz-progress').textContent = `Frage ${state.index + 1} von ${state.quizQuestions.length}`;
  document.getElementById('quiz-score').textContent = `Punkte: ${state.score}`;
  document.getElementById('q-file-ref').textContent = `${ROLE_LABEL[state.role] || 'GEN'} · ${String(state.index + 1).padStart(2,'0')}`;
  document.getElementById('q-law-tag').textContent = LAW_LABEL[q.source_law] || 'DSGVO + KI-VO';
  document.getElementById('q-text').textContent = q.text;

  const optsWrap = document.getElementById('q-options');
  optsWrap.innerHTML = '';
  q.options.forEach((opt, i) => {
    const div = document.createElement('div');
    div.className = 'option';
    div.innerHTML = `<span class="idx">${String.fromCharCode(65+i)}</span><span>${opt}</span>`;
    div.addEventListener('click', () => selectOption(i, div));
    optsWrap.appendChild(div);
  });

  document.getElementById('explain-box').classList.add('hidden');
  document.getElementById('next-btn').disabled = true;
}

function selectOption(i, el){
  if (state.answered) return;
  state.answered = true;
  const q = state.quizQuestions[state.index];
  const options = document.querySelectorAll('#q-options .option');
  options.forEach((opt, idx) => {
    opt.classList.add('disabled');
    if (idx === q.correct) opt.classList.add('correct');
    else if (idx === i) opt.classList.add('incorrect');
  });
  if (i === q.correct) state.score++;
  else state.missed.push(q);

  document.getElementById('explain-text').textContent = q.explanation;
  document.getElementById('explain-box').classList.remove('hidden');
  document.getElementById('quiz-score').textContent = `Punkte: ${state.score}`;
  document.getElementById('next-btn').disabled = false;
}

document.getElementById('next-btn').addEventListener('click', () => {
  if (state.index + 1 < state.quizQuestions.length){
    state.index++;
    renderQuestion();
  } else {
    showResults();
  }
});

/* ============ RESULTS ============ */
function showResults(){
  document.getElementById('quiz-screen').classList.add('hidden');
  document.getElementById('results-screen').classList.remove('hidden');
  const total = state.quizQuestions.length;
  document.getElementById('results-score').textContent = `${state.score} / ${total}`;
  document.getElementById('results-sub').textContent =
    `${ROLE_LABEL[state.role] || 'Allgemein'} · ${state.depth === 'core' ? 'Grundlagen' : 'Vertiefung'} · ${LAW_LABEL[state.law]}`;

  // simple pct bar
  const pct = Math.round((state.score / total) * 100);
  const bars = document.getElementById('results-bars');
  bars.innerHTML = `
    <div class="bar-row">
      <div class="bar-label"><span>Gesamt</span><span>${pct}%</span></div>
      <div class="bar-track"><div class="bar-fill" style="width:${pct}%"></div></div>
    </div>
  `;

  document.getElementById('results-advice-text').innerHTML = buildAdviceText(pct);
}

function buildAdviceText(pct){
  const roleLabel = ROLE_LABEL[state.role] || 'dein Team';

  // tier-based headline
  let headline;
  if (pct >= 90) {
    headline = `Starkes Ergebnis. Du hast ein solides Verständnis davon, wie die DSGVO und die EU-KI-Verordnung auf ${roleLabel === 'dein Team' ? 'deinen Arbeitsalltag' : 'die Arbeit im Bereich ' + roleLabel} zutreffen.`;
  } else if (pct >= 70) {
    headline = `Insgesamt ein gutes Ergebnis, mit ein paar Lücken, die sich lohnen zu schließen, bevor ein echter Anwendungsfall ansteht.`;
  } else if (pct >= 50) {
    headline = `Ein gemischtes Ergebnis. Die Grundlagen sind da, aber es fehlt genug, dass sich ein zweiter Blick auf die falsch beantworteten Fragen lohnt.`;
  } else {
    headline = `Das ist ein guter Ausgangspunkt, kein Urteil. Betrachte die verpassten Fragen unten als Leseliste, bevor du in eine KI-Rollout-Entscheidung involviert bist.`;
  }

  // flag any missed high-stakes items
  const missedSevere = state.missed.filter(q => q.risk_tier === 'unacceptable' || q.risk_tier === 'high_risk');
  let severeNote = '';
  if (missedSevere.length > 0) {
    severeNote = ` Wichtiger Hinweis: ${missedSevere.length} der verpassten Fragen betrafen ${missedSevere.some(q => q.risk_tier === 'unacceptable') ? 'Praktiken, die ausdrücklich verboten sind' : 'Hochrisiko-Einstufungen'} nach der KI-Verordnung. Das sind die Themen mit den größten Konsequenzen bei einer Fehleinschätzung in der Praxis, deshalb lohnt es sich, diese zuerst noch einmal durchzugehen.`;
  }

  return headline + severeNote;
}
